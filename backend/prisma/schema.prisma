generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password_hash String
  created_at    DateTime @default(now())
  
  members       Member[]
}

model Group {
  id         String    @id @default(uuid())
  name       String
  created_at DateTime  @default(now())

  members     Member[]
  expenses    Expense[]
  settlements Settlement[]
}

model Member {
  id         String    @id @default(uuid())
  user_id    String
  group_id   String
  name       String

  user       User      @relation(fields: [user_id], references: [id])
  group      Group     @relation(fields: [group_id], references: [id])
  
  paid_expenses        Expense[]             @relation("PaidBy")
  splits               ExpenseSplit[]
  confirmations        ExpenseConfirmation[]
  settlements_from     Settlement[]          @relation("SettlementFrom")
  settlements_to       Settlement[]          @relation("SettlementTo")
}

model Expense {
  id                    String   @id @default(uuid())
  group_id              String
  paid_by               String
  amount                Decimal  @db.Decimal(10, 2)
  description           String
  created_at            DateTime @default(now())
  origin_device         String?
  supersedes_expense_id String?  @unique

  group         Group                 @relation(fields: [group_id], references: [id])
  payer         Member                @relation("PaidBy", fields: [paid_by], references: [id])
  superseded_by Expense?              @relation("Supersedes", fields: [supersedes_expense_id], references: [id])
  supersedes    Expense?              @relation("Supersedes")

  splits        ExpenseSplit[]
  confirmations ExpenseConfirmation[]
}

model ExpenseSplit {
  id         String  @id @default(uuid())
  expense_id String
  member_id  String
  share      Decimal @db.Decimal(10, 2)

  expense    Expense @relation(fields: [expense_id], references: [id])
  member     Member  @relation(fields: [member_id], references: [id])
}

model ExpenseConfirmation {
  id           String    @id @default(uuid())
  expense_id   String
  member_id    String
  status       String    @default("pending")
  created_at   DateTime  @default(now())

  expense      Expense   @relation(fields: [expense_id], references: [id])
  member       Member    @relation(fields: [member_id], references: [id])
}

// Immutable payment record — INSERT only, never UPDATE/DELETE
model Settlement {
  id             String   @id @default(uuid())
  group_id       String
  from_member_id String
  to_member_id   String
  amount         Decimal  @db.Decimal(10, 2)
  created_at     DateTime @default(now())

  group          Group    @relation(fields: [group_id], references: [id])
  from_member    Member   @relation("SettlementFrom", fields: [from_member_id], references: [id])
  to_member      Member   @relation("SettlementTo", fields: [to_member_id], references: [id])
}
